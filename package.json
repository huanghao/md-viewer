{
  "name": "md-viewer",
  "version": "1.0.0",
  "description": "Markdown viewer with live reload",
  "type": "module",
  "bin": {
    "md-viewer-cli": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch run src/server.ts",
    "build": "bun build src/server.ts --compile --outfile=md-viewer",
    "cli": "bun run src/cli.ts"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "hono": "^3.12.8",
    "marked": "^11.1.1",
    "marked-highlight": "^2.0.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
