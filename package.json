{
  "name": "md-viewer",
  "version": "1.0.0",
  "description": "Markdown viewer with live reload",
  "type": "module",
  "bin": {
    "mdv": "./src/cli.ts",
    "mdv-admin": "./src/cli-admin.ts"
  },
  "scripts": {
    "build:client": "bun run build.ts",
    "build:client:watch": "bun run build.ts --watch",
    "dev": "bun --watch run src/server.ts",
    "build": "bun run build:client && bun build src/server.ts --compile --outfile=md-viewer",
    "cli": "bun run src/cli.ts",
    "admin": "bun run src/cli-admin.ts",
    "test:e2e": "playwright test",
    "test:e2e:video": "playwright test -c playwright.video.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:update": "playwright test --update-snapshots",
    "postinstall": "bash scripts/install-iterm2-dispatcher.sh"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "highlight.js": "^11.9.0",
    "hono": "^3.12.8",
    "marked": "^11.1.1",
    "marked-highlight": "^2.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/bun": "latest",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
